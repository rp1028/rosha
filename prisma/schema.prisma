generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 회차 (ex: 2026년 3회차 입시평가회)
model Session {
  id                String        @id @default(uuid())
  title             String        // "2026년 3회차 입시평가회"
  description       String?
  date              DateTime      // 평가 당일
  registrationStart DateTime?     // 신청 시작일 (선택)
  registrationEnd   DateTime?     // 신청 마감일 (팝업 종료 기준)
  resultUnlockedAt  DateTime?     // null=결과 잠김, 값 있으면=자동 열람 허용
  adminSummary      String?       // 관리자 종합 코멘트 (학생에게 표시)
  status            SessionStatus @default(RECRUITING)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  applications      Application[]
  criteria          EvaluationCriteria[]
}

enum SessionStatus {
  RECRUITING
  IN_PROGRESS
  COMPLETED
}

// 학생 (동일인 판별: name + phone)
model Student {
  id           String        @id @default(uuid())
  name         String
  phone        String
  email        String
  school       String
  uniqueCode   String        @unique  // 고유번호 (로그인 ID) - 최초 신청 시 발급
  password     String        // bcrypt 해시
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]

  @@unique([name, phone])
}

// 신청 (학생 + 회차)
model Application {
  id          String            @id @default(uuid())
  desiredUniv String            // 희망 대학교
  studentId   String
  sessionId   String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  student     Student           @relation(fields: [studentId], references: [id])
  session     Session           @relation(fields: [sessionId], references: [id])
  evaluations Evaluation[]
  videos      Video[]
  sheetUrl    String?
  sheetTitle  String?
  annotations ScoreAnnotation[]

  @@unique([studentId, sessionId])
}

// 평가자 (선생님 / 관리자)
model Evaluator {
  id          String           @id @default(uuid())
  name        String
  loginId     String           @unique
  password    String
  role        EvalRole         @default(EVALUATOR)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  evaluations Evaluation[]
  annotations ScoreAnnotation[]
}

enum EvalRole {
  ADMIN
  EVALUATOR
}

// 평가 항목 (회차별 설정 가능: 음정, 리듬, 표현력 등)
model EvaluationCriteria {
  id        String   @id @default(uuid())
  sessionId String
  name      String   // ex: "음정", "리듬", "표현력"
  maxScore  Int      @default(10)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  session Session           @relation(fields: [sessionId], references: [id])
  scores  EvaluationScore[]

  @@unique([sessionId, name])
}

// 평가 (여러 선생님이 각각 평가)
model Evaluation {
  id            String      @id @default(uuid())
  applicationId String
  evaluatorId   String
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  application   Application      @relation(fields: [applicationId], references: [id])
  evaluator     Evaluator        @relation(fields: [evaluatorId], references: [id])
  scores        EvaluationScore[]

  @@unique([applicationId, evaluatorId])
}

// 세부 평가 점수 (항목별)
model EvaluationScore {
  id           String   @id @default(uuid())
  evaluationId String
  criteriaId   String
  score        Int

  evaluation Evaluation         @relation(fields: [evaluationId], references: [id])
  criteria   EvaluationCriteria @relation(fields: [criteriaId], references: [id])

  @@unique([evaluationId, criteriaId])
}

// 연주 영상
model Video {
  id            String   @id @default(uuid())
  applicationId String
  youtubeUrl    String
  title         String?
  createdAt     DateTime @default(now())

  application Application @relation(fields: [applicationId], references: [id])
}

// 악보 코멘트 (마디/구간별 메모)
model ScoreAnnotation {
  id            String         @id @default(uuid())
  applicationId String
  evaluatorId   String
  measureNumber Int?
  timePosition  String?        // "01:23" 형태 등 자유 텍스트
  tag           AnnotationTag?
  content       String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  application   Application    @relation(fields: [applicationId], references: [id])
  evaluator     Evaluator      @relation(fields: [evaluatorId], references: [id])

  @@index([applicationId])
  @@index([evaluatorId])
}

enum AnnotationTag {
  INTONATION
  RHYTHM
  TEMPO
  DYNAMICS
  EXPRESSION
  OTHER
}
